# Healthcare Triage Workflow
#
# Simulates a hospital environment where a triage nurse interviews the patient,
# determines which specialist to refer them to, and then the specialist examines
# the patient. The specialist may refer to another specialist or set a diagnosis.
#
# Usage:
#   zig run examples/healthcare/healthcare.toml "I've been having chest pain and shortness of breath for two days"
#
# Or pack and distribute:
#   zig workflow pack examples/healthcare/ -o healthcare.zwfz
#   zig run healthcare.zwfz "I've been having headaches and blurry vision"

[workflow]
name = "healthcare-triage"
description = "Hospital triage simulation with nurse intake and specialist referral"
tags = ["healthcare", "simulation", "roles"]
version = "1.0.0"
provider = "claude"
memory = "all"
resources = [
  { path = "./resources/patient-profile.md", name = "patient-profile", description = "Your personal health information — allergies, medications, conditions", required = false },
  { path = "./resources/dropbox", name = "dropbox", description = "Drop any relevant files here — lab results, imaging reports, doctor's letters, insurance docs", required = false },
  { path = "./resources/triage-guidelines.md", name = "triage-guidelines", description = "ESI triage reference and severity classification guide" },
]

# ── Roles ────────────────────────────────────────────────────────────────────

[roles.nurse-triage]
system_prompt_file = "prompts/nurse-triage.md"

[roles.cardiologist]
system_prompt_file = "prompts/cardiologist.md"

[roles.neurologist]
system_prompt_file = "prompts/neurologist.md"

[roles.dermatologist]
system_prompt_file = "prompts/dermatologist.md"

[roles.orthopedist]
system_prompt_file = "prompts/orthopedist.md"

[roles.gastroenterologist]
system_prompt_file = "prompts/gastroenterologist.md"

[roles.pulmonologist]
system_prompt_file = "prompts/pulmonologist.md"

[roles.endocrinologist]
system_prompt_file = "prompts/endocrinologist.md"

[roles.urologist]
system_prompt_file = "prompts/urologist.md"

[roles.ophthalmologist]
system_prompt_file = "prompts/ophthalmologist.md"

[roles.ent-specialist]
system_prompt_file = "prompts/ent-specialist.md"

[roles.rheumatologist]
system_prompt_file = "prompts/rheumatologist.md"

[roles.oncologist]
system_prompt_file = "prompts/oncologist.md"

[roles.psychiatrist]
system_prompt_file = "prompts/psychiatrist.md"

[roles.psychologist]
system_prompt_file = "prompts/psychologist.md"

[roles.dietitian]
system_prompt_file = "prompts/dietitian.md"

[roles.physical-therapist]
system_prompt_file = "prompts/physical-therapist.md"

[roles.allergist]
system_prompt_file = "prompts/allergist.md"

[roles.nephrologist]
system_prompt_file = "prompts/nephrologist.md"

[roles.emergency-physician]
system_prompt_file = "prompts/emergency-physician.md"

# ── Storage ─────────────────────────────────────────────────────────────────

[storage.patient_records]
type = "folder"
path = "./patient-records"
description = "Visit records from each consultation, one file per visit"
hint = "Filename: <date>-<specialist>.md. Include chief complaint, assessment, plan."

[storage.treatment_plans]
type = "folder"
path = "./treatment-plans"
description = "Treatment plans produced by specialists"
hint = "Filename: <date>-<diagnosis-slug>.md. Include diagnosis, medications, follow-up."

# ── Variables ────────────────────────────────────────────────────────────────

[vars.symptoms]
type = "string"
from = "prompt"
required = true
description = "Patient's reported symptoms and complaints"

[vars.specialist_type]
type = "string"
default = ""
description = "The specialist to refer the patient to (set by triage nurse or previous specialist)"

[vars.triage_notes]
type = "string"
default = ""
description = "Triage nurse assessment notes passed to the specialist"

[vars.diagnosis]
type = "string"
default = ""
description = "Final or working diagnosis set by a specialist"

[vars.needs_referral]
type = "bool"
default = false
description = "Whether the current specialist is referring to another specialist"

[vars.referral_reason]
type = "string"
default = ""
description = "Reason for referral to the next specialist"

[vars.visit_history]
type = "string"
default = ""
description = "Accumulated notes from all specialist visits so far"

[vars.severity_level]
type = "string"
default = ""
description = "ESI severity level (1-5) assigned by the triage nurse"

[vars.treatment_plan]
type = "string"
default = ""
description = "Treatment plan set by the specialist upon diagnosis"

# ── Steps ────────────────────────────────────────────────────────────────────

[[step]]
name = "triage"
prompt = """Patient presents with the following complaints:

${symptoms}

Check the patient profile resource for known allergies, medications, and medical history. Check the dropbox for any additional documents the patient brought (lab results, imaging, referral letters).

Review any prior visit records in storage for relevant history.

Conduct a triage assessment. Ask clarifying questions mentally (simulate the interview), assess severity using the ESI guidelines, and determine which specialist the patient should see.

Save a visit record to storage summarizing this triage encounter.

Respond in JSON format."""
role = "nurse-triage"
json = true
saves = { specialist_type = "$.specialist_type", triage_notes = "$.triage_notes", severity_level = "$.severity_level" }
storage = ["patient_records"]
description = "Triage nurse interviews the patient and determines specialist referral"

[[step]]
name = "specialist"
prompt = """You are seeing a patient referred to you.

**Triage Notes:** ${triage_notes}

**ESI Severity Level:** ${severity_level}

**Patient Symptoms:** ${symptoms}

**Previous Visit Notes:** ${visit_history}

**Referral Reason:** ${referral_reason}

Check the patient profile resource and dropbox for relevant medical history, lab results, or other documents.

Review prior visit records and treatment plans in storage for context.

Examine the patient. Based on the symptoms and history:
1. Conduct a focused assessment within your specialty
2. Either set a diagnosis or refer to another specialist
3. If diagnosing, produce a treatment plan

Save a visit record and, if diagnosing, a treatment plan to storage.

Respond in JSON format."""
role = "${specialist_type}"
depends_on = ["triage"]
model = "large"
json = true
condition = "specialist_type"
saves = { diagnosis = "$.diagnosis", needs_referral = "$.needs_referral", specialist_type = "$.next_specialist", referral_reason = "$.referral_reason", visit_history = "$.visit_notes", treatment_plan = "$.treatment_plan" }
storage = ["patient_records", "treatment_plans"]
next = "specialist"
description = "Specialist examines the patient and either diagnoses or refers"
max_turns = 5
